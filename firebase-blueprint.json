{
  "entities": {
    "CourseApplication": {
      "title": "Course Application",
      "description": "Information about a user applying for a course",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the applicant"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the applicant"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the applicant"
        },
        "courseId": {
          "type": "string",
          "description": "ID of the course applied for"
        },
        "courseTitle": {
          "type": "string",
          "description": "Title of the course applied for"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the application was submitted"
        }
      },
      "required": ["name", "email", "courseId", "courseTitle", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "DeletionRequest": {
      "title": "Deletion Request",
      "description": "Request from a user to delete their data",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "status", "createdAt"]
    }
  },
  "firestore": {
    "/applications/{applicationId}": {
      "schema": "CourseApplication",
      "description": "Collection of course applications"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of registered users"
    },
    "/deletion_requests/{requestId}": {
      "schema": "DeletionRequest",
      "description": "Collection of data deletion requests"
    }
  }
}
